//+------------------------------------------------------------------+
//|                                                     SMC_Buy.mq4  |
//|                                         Generated by Antigravity |
//+------------------------------------------------------------------+
#property copyright "Antigravity AI"
#property strict
#property show_inputs

input string   Settings = "--- AJUSTES DE RIESGO ---";
input double   RiskPercent = 1.0;         // Riesgo por operacion (%)
input bool     Auto_SL = true;            // SL automatico en el ultimo minimo
input int      Auto_SL_Bars = 15;         // Velas para buscar el minimo
input double   Manual_SL_Pips = 10.0;     // SL manual en pips (si Auto_SL es false)
input double   Target_RR = 2.0;           // Ratio Beneficio/Riesgo (0 = sin TP)
input int      MagicNumber = 0;           // 0 = Operacion manual (independiente del EA)

void OnStart()
  {
   double slPrice = 0;
   double slPips = 0;
   double tpPrice = 0;
   
   if(Auto_SL)
     {
      int lowestIdx = iLowest(Symbol(), Period(), MODE_LOW, Auto_SL_Bars, 0);
      if(lowestIdx < 0) { Print("Error buscando minimo."); return; }
      // SL 1 pip por debajo del minimo (10 points)
      slPrice = NormalizeDouble(Low[lowestIdx] - 10 * Point, Digits);
      slPips = (Ask - slPrice) / (10 * Point);
      
      // Proteccion minima de 2 pips para que no de error
      if(slPips < 2.0) 
        {
         slPips = 2.0;
         slPrice = NormalizeDouble(Ask - slPips * 10 * Point, Digits);
        }
     }
   else
     {
      slPips = Manual_SL_Pips;
      slPrice = NormalizeDouble(Ask - slPips * 10 * Point, Digits);
     }
     
   double tickValue = MarketInfo(Symbol(), MODE_TICKVALUE);
   if(tickValue == 0) { Print("Error tickValue"); return; }
   
   double riskAmount = AccountBalance() * (RiskPercent / 100.0);
   double slPoints = slPips * 10.0;
   double lot = riskAmount / (slPoints * tickValue);
   
   double minLot = MarketInfo(Symbol(), MODE_MINLOT);
   double maxLot = MarketInfo(Symbol(), MODE_MAXLOT);
   double lotStep = MarketInfo(Symbol(), MODE_LOTSTEP);
   
   if(lot < minLot) lot = minLot;
   if(lot > maxLot) lot = maxLot;
   lot = MathFloor(lot / lotStep) * lotStep;
   
   if(Target_RR > 0)
     {
      tpPrice = NormalizeDouble(Ask + (slPips * 10 * Point * Target_RR), Digits);
     }
   
   int ticket = OrderSend(Symbol(), OP_BUY, lot, Ask, 3, slPrice, tpPrice, "SMC Manual Buy", MagicNumber, 0, clrBlue);
   
   if(ticket > 0)
     {
      Print("SMC Compra ejecutada. Lote: ", DoubleToStr(lot, 2), " SL: ", DoubleToStr(slPips, 1), " pips.");
     }
   else
     {
      Print("Error al ejecutar compra SMC: ", GetLastError());
     }
  }
//+------------------------------------------------------------------+
